                           </children>
                        </HBox>
                        
                        <HBox spacing="15.0">
                           <children>
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="btn-outline" text="+ Apal berria" HBox.hgrow="ALWAYS" />
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="btn-outline" text="↓ Auditoria CSV" HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>
                     </children>
