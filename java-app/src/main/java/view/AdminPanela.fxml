                              <Label styleClass="badge-success" text="BAI/EZ" />
                           </children>
                        </HBox>
                        
                        <HBox alignment="CENTER_LEFT" styleClass="status-row">
                           <children>
                              <Label style="-fx-text-fill: #374151;" styleClass="font-bold" text="Azken babes-kopia" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label styleClass="badge-success" text="Gaur 03:00" />
                           </children>
                        </HBox>
                        
                        <HBox alignment="CENTER_LEFT" styleClass="status-row-last">
                           <children>
                              <Label style="-fx-text-fill: #374151;" styleClass="font-bold" text="E-posta (SMTP)" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label styleClass="badge-success" text="Aktibo" />
                           </children>
                        </HBox>
                     </children>
                     <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                     </padding>
                  </VBox>

                  <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label style="-fx-font-size: 16px;" styleClass="font-bold, text-dark" text="Sarbide azkarrak">
                           <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                        </Label>

                        <HBox spacing="15.0">
                           <children>
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="btn-outline" text="+ Langile berria" HBox.hgrow="ALWAYS" />
