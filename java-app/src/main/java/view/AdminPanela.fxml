                  </VBox>
                  <VBox styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="kpi-label" text="KOKALEKUAK" />
                        <Label styleClass="kpi-value, text-dark" text="9" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>

                  <VBox spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label style="-fx-font-size: 16px;" styleClass="font-bold, text-dark" text="Sistemaren egoera">
                           <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                        </Label>

                        <HBox alignment="CENTER_LEFT" styleClass="status-row">
                           <children>
                              <Label style="-fx-text-fill: #374151;" styleClass="font-bold" text="Datu-basearen konexioa" />
