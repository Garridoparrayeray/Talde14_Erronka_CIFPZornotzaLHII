            <Label styleClass="font-title" text="Administrazio Panela">
               <font><Font size="20.0" /></font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
         </children>
      </HBox>

      <VBox spacing="30.0" VBox.vgrow="ALWAYS">
         <children>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Label styleClass="font-title" text="Administrazio Panela" />
                  <Label styleClass="badge-primary" text="ADMIN" />
               </children>
            </HBox>

            <HBox spacing="20.0">
               <children>
                  <VBox styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="kpi-label" text="LANGILEAK" />
                        <Label styleClass="kpi-value, text-primary" text="6" />
                     </children>
                  </VBox>
                  <VBox styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="kpi-label" text="ARTIKULUAK" />
