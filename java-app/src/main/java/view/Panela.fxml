<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox styleClass="bg-light" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox alignment="CENTER_LEFT" style="-fx-border-color: transparent transparent #E5E7EB transparent; -fx-padding: 15 30;" styleClass="bg-white">
         <children>
            <Label styleClass="font-title" text="Panela">
               <font><Font size="20.0" /></font>
            </Label>
         </children>
      </HBox>

      <VBox spacing="30.0" VBox.vgrow="ALWAYS">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label styleClass="font-title" text="Egun on, Aitor" />
                  <Label styleClass="font-subtitle" text="Gaur, 19 apr 2026 · Bermeoko biltegiaren egoera orokorra" />
               </children>
            </VBox>

            <HBox spacing="20.0">
               <children>
                  <VBox style="-fx-padding: 20;" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="kpi-label" text="BILTEGIAN" />
                        <Label styleClass="kpi-value, text-primary" text="13" />
                        <Label styleClass="badge-primary" text="+7 aste honetan">
                           <VBox.margin><Insets top="10.0" /></VBox.margin>
                        </Label>
                     </children>
                  </VBox>
                  <VBox style="-fx-padding: 20;" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="kpi-label" text="ERREKLAMAZIO IREKIAK" />
                        <Label styleClass="kpi-value, text-primary" text="3" />
                     </children>
                  </VBox>
                  <VBox style="-fx-padding: 20;" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="kpi-label" text="IRAUNGITZEAR" />
                        <Label styleClass="kpi-value, text-warning" text="1" />
                     </children>
                  </VBox>
                  <VBox style="-fx-padding: 20;" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="kpi-label" text="IRAUNGITUAK" />
                        <Label styleClass="kpi-value, text-dark" text="2" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox spacing="15.0" style="-fx-padding: 20;" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label style="-fx-font-size: 16px;" styleClass="font-bold, text-dark" text="Azken mugimenduak" />
                        <TableView styleClass="table-view" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn prefWidth="200.0" text="Artikulua" />
                              <TableColumn prefWidth="170.0" text="ID" />
                              <TableColumn prefWidth="157.0" text="Mota" />
                              <TableColumn prefWidth="219.0" text="Ordua" />
                           </columns>
                        </TableView>
                     </children>
                  </VBox>

                  <VBox prefWidth="350.0" spacing="15.0" style="-fx-padding: 20;" styleClass="card" HBox.hgrow="NEVER">
                     <children>
                        <Label style="-fx-font-size: 16px;" styleClass="font-bold, text-dark" text="Kategoriak" />
                        <TableView styleClass="table-view" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn prefWidth="156.0" text="Kategoria" />
                              <TableColumn prefWidth="150.0" text="Kop." />
                           </columns>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
      </VBox>
   </children>
</VBox>
