<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox styleClass="bg-light" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>

      <HBox alignment="CENTER_LEFT" style="-fx-border-color: transparent transparent #E5E7EB transparent; -fx-padding: 15 30;" styleClass="bg-white">
         <children>
            <Label styleClass="font-title" text="Auditoria">
               <font><Font size="20.0" /></font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
         </children>
      </HBox>

      <VBox spacing="20.0" VBox.vgrow="ALWAYS">
         <children>

            <VBox spacing="20.0" styleClass="card" VBox.vgrow="ALWAYS">
               <children>

                  <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <children>
                        <TextField prefWidth="300.0" promptText="Bilatu langile, ekintza edo ID..." styleClass="form-control" HBox.hgrow="ALWAYS" />
                        <ComboBox prefWidth="150.0" promptText="Ekintza guztiak" styleClass="form-select" />

                        <DatePicker prefWidth="150.0" promptText="12/04/2026" styleClass="date-picker" />
                        <DatePicker prefWidth="150.0" promptText="19/04/2026" styleClass="date-picker" />

                        <Button mnemonicParsing="false" styleClass="btn-outline" text="CSV esportatu" />
                     </children>
                  </HBox>
                  <ScrollPane VBox.vgrow="ALWAYS">
                     <content>
      
                        <TableView styleClass="table-view">
                          <columns>
                            <TableColumn prefWidth="180.0" text="DATA" />
                            <TableColumn prefWidth="250.0" text="LANGILEA" />
                            <TableColumn prefWidth="180.0" text="EKINTZA" />
                            <TableColumn prefWidth="350.0" text="XEHETASUNAK" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </content>
                  </ScrollPane>

               </children>
               <padding>
                  <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
               </padding>
            </VBox>

         </children>
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
      </VBox>
   </children>
</VBox>
