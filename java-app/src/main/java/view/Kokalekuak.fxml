<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox styleClass="bg-light" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox alignment="CENTER_LEFT" style="-fx-border-color: transparent transparent #E5E7EB transparent; -fx-padding: 15 30;" styleClass="bg-white">
         <children>
            <Label styleClass="font-title" text="Kokalekuak">
               <font><Font size="20.0" /></font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
         </children>
      </HBox>

      <VBox spacing="20.0" style="-fx-padding: 30;" VBox.vgrow="ALWAYS">
         <children>
            <VBox spacing="20.0" style="-fx-padding: 25;" styleClass="card" VBox.vgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <VBox>
                           <children>
                              <Label styleClass="font-bold, text-dark" text="Armairu eta apalen egitura" />
                              <Label style="-fx-font-size: 12px;" styleClass="text-muted" text="Biltegiko apal bakoitzaren edukiera" />
                           </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" styleClass="btn-primary" text="+ Apal berria" />
                     </children>
                  </HBox>

                  <TableView styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn prefWidth="100.0" text="ID" />
                      <TableColumn prefWidth="150.0" text="ARMAIRUA" />
                      <TableColumn prefWidth="150.0" text="APALA" /> 
                      <TableColumn prefWidth="120.0" text="ARTIKULUAK" />
                      <TableColumn prefWidth="200.0" text="MOTA" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</VBox>
