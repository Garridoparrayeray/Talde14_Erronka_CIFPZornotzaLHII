<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox styleClass="bg-light" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox alignment="CENTER_LEFT" style="-fx-border-color: transparent transparent #E5E7EB transparent; -fx-padding: 15 30;" styleClass="bg-white">
         <children>
            <Label styleClass="font-title" text="Erregistroa">
               <font><Font size="20.0" /></font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
         </children>
      </HBox>

      <HBox spacing="20.0" VBox.vgrow="ALWAYS">
         <children>

            <VBox prefWidth="500.0" spacing="20.0" styleClass="card" HBox.hgrow="ALWAYS">
               <children>
                  <Label style="-fx-font-size: 16px;" styleClass="font-bold, text-dark" text="Artikuluaren datuak" />

                  <VBox spacing="8.0">
                     <children>
                        <Label style="-fx-text-fill: #374151;" styleClass="font-bold" text="Izena *" />
                        <TextField promptText="Adib.: Eskola-motxila" styleClass="form-control" />
                     </children>
                  </VBox>

                  <HBox spacing="15.0">
                     <children>
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>

                  <VBox spacing="8.0">
                     <children>
                        <Label style="-fx-text-fill: #374151;" styleClass="font-bold" text="Kategoria *" />
                        <ComboBox maxWidth="1.7976931348623157E308" promptText="— Hautatu —" styleClass="form-select" />
                     </children>
                  </VBox>

                  <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                     <children>
                        <Label style="-fx-text-fill: #374151;" styleClass="font-bold" text="Deskribapena" />
                        <TextArea prefHeight="100.0" promptText="Ezaugarri bereizgarriak, etiketak, edukia..." styleClass="text-area" VBox.vgrow="ALWAYS" />
                     </children>
                  </VBox>

                  <HBox spacing="15.0">
                     <children>
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label style="-fx-text-fill: #374151;" styleClass="font-bold" text="Aurkipen-lekua" />
                              <TextField promptText="Adib.: Portua" styleClass="form-control" />
                           </children>
                        </VBox>
                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label style="-fx-text-fill: #374151;" styleClass="font-bold" text="Sarrera-data" />
                              <DatePicker maxWidth="1.7976931348623157E308" promptText="19/04/2026" styleClass="date-picker" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
               </padding>
            </VBox>

            <VBox prefWidth="500.0" spacing="20.0" styleClass="card" HBox.hgrow="ALWAYS">
               <children>
                  <Label style="-fx-font-size: 16px;" styleClass="font-bold, text-dark" text="Kokalekua eta argazkia" />

                  <VBox spacing="8.0">
                     <children>
                        <Label style="-fx-text-fill: #374151;" styleClass="font-bold" text="Biltegiko kokalekua" />
                        <ComboBox maxWidth="1.7976931348623157E308" promptText="A-01 · Armairua A, apala 01" styleClass="form-select" />
                     </children>
                  </VBox>

                  <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                     <children>
                        <Label style="-fx-text-fill: #374151;" styleClass="font-bold" text="Argazkia" />
                        <VBox spacing="10.0" styleClass="upload-zone" VBox.vgrow="ALWAYS">
                           <children>
                              <Label style="-fx-text-fill: #9CA3AF; -fx-font-size: 32px;" text="↓" />
                              <Label style="-fx-text-fill: #4B5563; -fx-font-size: 14px;" text="Jaregin irudia hemen" />
                              <Label style="-fx-text-fill: #9CA3AF; -fx-font-size: 12px;" text="edo" />
                              <Button mnemonicParsing="false" styleClass="btn-outline" text="Aukeratu fitxategia..." />
                              <Label style="-fx-text-fill: #9CA3AF; -fx-font-size: 11px;" text="JPG, PNG · max 5 MB">
                                 <VBox.margin><Insets top="10.0" /></VBox.margin>
                              </Label>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <HBox alignment="BOTTOM_RIGHT" spacing="15.0">
                     <children>
                        <Button mnemonicParsing="false" styleClass="btn-outline" text="Utzi" />
                        <Button mnemonicParsing="false" styleClass="btn-primary" text="Erregistratu" />
                     </children>
                     <VBox.margin>
                        <Insets top="10.0" />
                     </VBox.margin>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
               </padding>
            </VBox>

         </children>
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
      </HBox>
   </children>
</VBox>
